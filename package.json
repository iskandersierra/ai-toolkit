{
  "name": "ai-toolkit",
  "displayName": "ai-toolkit",
  "description": "Collections of AI oriented tools",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.vscode/ai-toolkit.annotations.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-toolkit.addOrEditAnnotation",
        "title": "AI Toolkit: Add or Edit Annotation",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.selectReviewSession",
        "title": "AI Toolkit: Select Review Session",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.generateDraftOutput",
        "title": "AI Toolkit: Generate Draft Output",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.purgeDismissedAnnotations",
        "title": "AI Toolkit: Purge Dismissed Annotations",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.reanchorAnnotation",
        "title": "AI Toolkit: Reanchor Annotation",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.dismissAnnotation",
        "title": "AI Toolkit: Dismiss Annotation",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.resolveAnnotation",
        "title": "AI Toolkit: Resolve Annotation",
        "category": "AI Toolkit"
      },
      {
        "command": "ai-toolkit.reopenAnnotation",
        "title": "AI Toolkit: Reopen Annotation",
        "category": "AI Toolkit"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ai-toolkit.addOrEditAnnotation"
        },
        {
          "command": "ai-toolkit.selectReviewSession"
        },
        {
          "command": "ai-toolkit.generateDraftOutput"
        },
        {
          "command": "ai-toolkit.purgeDismissedAnnotations"
        },
        {
          "command": "ai-toolkit.reanchorAnnotation",
          "when": "aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.dismissAnnotation",
          "when": "aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.resolveAnnotation",
          "when": "aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.reopenAnnotation",
          "when": "aiToolkit.annotation.canManage"
        }
      ],
      "editor/context": [
        {
          "command": "ai-toolkit.addOrEditAnnotation",
          "group": "navigation@10",
          "when": "editorTextFocus"
        },
        {
          "command": "ai-toolkit.reanchorAnnotation",
          "group": "navigation@11",
          "when": "editorTextFocus && aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.dismissAnnotation",
          "group": "navigation@12",
          "when": "editorTextFocus && aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.resolveAnnotation",
          "group": "navigation@13",
          "when": "editorTextFocus && aiToolkit.annotation.canManage"
        },
        {
          "command": "ai-toolkit.reopenAnnotation",
          "group": "navigation@14",
          "when": "editorTextFocus && aiToolkit.annotation.canManage"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "ai-toolkit.resolveAnnotation",
          "group": "annotation@1",
          "when": "commentController == ai-toolkit-annotations"
        },
        {
          "command": "ai-toolkit.reopenAnnotation",
          "group": "annotation@1",
          "when": "commentController == ai-toolkit-annotations"
        },
        {
          "command": "ai-toolkit.dismissAnnotation",
          "group": "annotation@2",
          "when": "commentController == ai-toolkit-annotations"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-toolkit.addOrEditAnnotation",
        "key": "ctrl+shift+a a",
        "when": "editorTextFocus && (editorHasSelection || aiToolkit.annotation.canManage)"
      },
      {
        "command": "ai-toolkit.selectReviewSession",
        "key": "ctrl+shift+a s",
        "when": "workspaceFolderCount > 0"
      },
      {
        "command": "ai-toolkit.generateDraftOutput",
        "key": "ctrl+shift+a d",
        "when": "workspaceFolderCount > 0 && aiToolkit.annotation.hasActiveSession"
      }
    ],
    "configuration": {
      "title": "AI Toolkit",
      "properties": {
        "aiToolkit.draftOutputFormat": {
          "type": "string",
          "enum": [
            "markdown",
            "json",
            "yaml"
          ],
          "default": "markdown",
          "markdownDescription": "Controls the output format used by `AI Toolkit: Generate Draft Output`."
        },
        "aiToolkit.comments.showOnlyActiveSession": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Shows comment projections only for the active review session."
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": ".vscode/ai-toolkit.annotations.json",
        "url": "./schemas/ai-toolkit.annotations.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "node ./scripts/run-vscode-test.mjs",
    "test:coverage": "node ./scripts/run-vscode-test.mjs --coverage"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
